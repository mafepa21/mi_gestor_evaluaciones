lastInsertedId:
SELECT last_insert_rowid();

insertAiAuditEvent:
INSERT INTO ai_audit_events(
    created_at_epoch_ms, service, use_case, report_kind, class_id, student_hash,
    availability, model_available, success, duration_ms, error_kind, error_message
)
VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?);

selectAiAuditEvents:
SELECT id, created_at_epoch_ms, service, use_case, report_kind, class_id, student_hash,
       availability, model_available, success, duration_ms, error_kind, error_message
FROM ai_audit_events
ORDER BY created_at_epoch_ms DESC
LIMIT ?;

selectRecentAiAuditFailures:
SELECT id, created_at_epoch_ms, service, use_case, report_kind, class_id, student_hash,
       availability, model_available, success, duration_ms, error_kind, error_message
FROM ai_audit_events
WHERE success = 0
ORDER BY created_at_epoch_ms DESC
LIMIT ?;

selectLatestAiAuditEvent:
SELECT id, created_at_epoch_ms, service, use_case, report_kind, class_id, student_hash,
       availability, model_available, success, duration_ms, error_kind, error_message
FROM ai_audit_events
ORDER BY created_at_epoch_ms DESC
LIMIT 1;

selectAiAuditTotalsByUseCase:
SELECT use_case, COUNT(*) AS total_count, SUM(success) AS success_count, MAX(created_at_epoch_ms) AS last_created_at_epoch_ms
FROM ai_audit_events
GROUP BY use_case
ORDER BY total_count DESC, use_case;

selectRecentAiAuditAvailability:
SELECT availability, COUNT(*) AS total_count, MAX(created_at_epoch_ms) AS last_created_at_epoch_ms
FROM ai_audit_events
GROUP BY availability
ORDER BY last_created_at_epoch_ms DESC;
