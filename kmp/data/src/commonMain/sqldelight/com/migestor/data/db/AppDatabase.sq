)
VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?);

CREATE TABLE IF NOT EXISTS notebook_tabs (
    id          TEXT NOT NULL PRIMARY KEY,
    class_id    INTEGER NOT NULL,
    title       TEXT NOT NULL,
    parent_tab_id TEXT,
    sort_order  INTEGER NOT NULL DEFAULT 0,
    updated_at_epoch_ms INTEGER NOT NULL DEFAULT 0,
    device_id   TEXT,
    sync_version INTEGER NOT NULL DEFAULT 0,
    FOREIGN KEY (class_id) REFERENCES classes(id) ON DELETE CASCADE,
    FOREIGN KEY (parent_tab_id) REFERENCES notebook_tabs(id) ON DELETE CASCADE
);
CREATE INDEX IF NOT EXISTS idx_tabs_class ON notebook_tabs(class_id);
CREATE INDEX IF NOT EXISTS idx_tabs_parent ON notebook_tabs(parent_tab_id, sort_order, id);

CREATE TABLE IF NOT EXISTS notebook_columns (
    id              TEXT NOT NULL PRIMARY KEY,
    class_id        INTEGER NOT NULL,
    title           TEXT NOT NULL,
    type            TEXT NOT NULL,         -- NotebookColumnType enum
    category_kind   TEXT NOT NULL DEFAULT 'CUSTOM',
    instrument_kind TEXT NOT NULL DEFAULT 'CUSTOM',
    input_kind      TEXT NOT NULL DEFAULT 'TEXT',
    evaluation_id   INTEGER,
    formula         TEXT,
    weight          REAL NOT NULL DEFAULT 1.0,
    date_epoch_ms   INTEGER,
    unit_name       TEXT,
    competency_criteria_ids_csv TEXT NOT NULL DEFAULT '',
    scale_kind      TEXT NOT NULL DEFAULT 'CUSTOM',
    tab_ids_csv     TEXT NOT NULL DEFAULT '',
    shared_across_tabs INTEGER NOT NULL DEFAULT 0,
    color_hex       TEXT NOT NULL DEFAULT '#FFFFFF',
    icon_name       TEXT,
    sort_order      INTEGER NOT NULL DEFAULT 0,
    width_dp        REAL NOT NULL DEFAULT 132.0,
    category_id     TEXT,
    visibility      TEXT NOT NULL DEFAULT 'VISIBLE',
    is_locked       INTEGER NOT NULL DEFAULT 0,
    updated_at_epoch_ms INTEGER NOT NULL DEFAULT 0,
    device_id       TEXT,
    sync_version    INTEGER NOT NULL DEFAULT 0,
    FOREIGN KEY (class_id) REFERENCES classes(id) ON DELETE CASCADE,
    FOREIGN KEY (evaluation_id) REFERENCES evaluations(id) ON DELETE SET NULL,
    FOREIGN KEY (category_id) REFERENCES notebook_column_categories(id) ON DELETE SET NULL
);
CREATE INDEX IF NOT EXISTS idx_columns_class ON notebook_columns(class_id);
CREATE INDEX IF NOT EXISTS idx_columns_class_category ON notebook_columns(class_id, category_id, sort_order, id);

CREATE TABLE IF NOT EXISTS notebook_column_categories (
    id                  TEXT NOT NULL PRIMARY KEY,
    class_id            INTEGER NOT NULL,
    tab_id              TEXT NOT NULL,
    name                TEXT NOT NULL,
    sort_order          INTEGER NOT NULL DEFAULT 0,
    is_collapsed        INTEGER NOT NULL DEFAULT 0,
    updated_at_epoch_ms INTEGER NOT NULL DEFAULT 0,
    device_id           TEXT,
    sync_version        INTEGER NOT NULL DEFAULT 0,
    FOREIGN KEY (class_id) REFERENCES classes(id) ON DELETE CASCADE,
    FOREIGN KEY (tab_id) REFERENCES notebook_tabs(id) ON DELETE CASCADE
);
CREATE INDEX IF NOT EXISTS idx_column_categories_class_tab ON notebook_column_categories(class_id, tab_id, sort_order, id);

CREATE TABLE IF NOT EXISTS notebook_work_groups (
    id              INTEGER PRIMARY KEY AUTOINCREMENT,
    class_id        INTEGER NOT NULL,
    tab_id          TEXT NOT NULL,
    name            TEXT NOT NULL,
    sort_order      INTEGER NOT NULL DEFAULT 0,
    updated_at_epoch_ms INTEGER NOT NULL DEFAULT 0,
    device_id       TEXT,
    sync_version    INTEGER NOT NULL DEFAULT 0,
    FOREIGN KEY (class_id) REFERENCES classes(id) ON DELETE CASCADE,
    FOREIGN KEY (tab_id) REFERENCES notebook_tabs(id) ON DELETE CASCADE
);
CREATE INDEX IF NOT EXISTS idx_work_groups_class_tab ON notebook_work_groups(class_id, tab_id, sort_order, id);

CREATE TABLE IF NOT EXISTS notebook_work_group_members (
    class_id        INTEGER NOT NULL,
    tab_id          TEXT NOT NULL,
    group_id        INTEGER NOT NULL,
    student_id      INTEGER NOT NULL,
    updated_at_epoch_ms INTEGER NOT NULL DEFAULT 0,
    device_id       TEXT,
    sync_version    INTEGER NOT NULL DEFAULT 0,
    PRIMARY KEY (class_id, tab_id, student_id),
    FOREIGN KEY (class_id) REFERENCES classes(id) ON DELETE CASCADE,
    FOREIGN KEY (tab_id) REFERENCES notebook_tabs(id) ON DELETE CASCADE,
    FOREIGN KEY (group_id) REFERENCES notebook_work_groups(id) ON DELETE CASCADE,
    FOREIGN KEY (student_id) REFERENCES students(id) ON DELETE CASCADE
);
CREATE INDEX IF NOT EXISTS idx_work_group_members_class_tab ON notebook_work_group_members(class_id, tab_id, group_id, student_id);

CREATE TABLE IF NOT EXISTS ai_audit_events (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    created_at_epoch_ms INTEGER NOT NULL,
    service TEXT NOT NULL,
    use_case TEXT NOT NULL,
    report_kind TEXT,
    class_id INTEGER,
    student_hash TEXT,
    availability TEXT NOT NULL,
    model_available INTEGER NOT NULL DEFAULT 0,
    success INTEGER NOT NULL DEFAULT 0,
    duration_ms INTEGER NOT NULL DEFAULT 0,
    error_kind TEXT,
    error_message TEXT
);
CREATE INDEX IF NOT EXISTS idx_ai_audit_created ON ai_audit_events(created_at_epoch_ms DESC);
CREATE INDEX IF NOT EXISTS idx_ai_audit_use_case ON ai_audit_events(use_case, created_at_epoch_ms DESC);
CREATE INDEX IF NOT EXISTS idx_ai_audit_success ON ai_audit_events(success, created_at_epoch_ms DESC);

selectTabsByClass:
SELECT id, class_id, title, parent_tab_id, sort_order, updated_at_epoch_ms, device_id, sync_version
FROM notebook_tabs
WHERE class_id = ?
ORDER BY sort_order, id;

upsertTab:
INSERT OR REPLACE INTO notebook_tabs(id, class_id, title, parent_tab_id, sort_order, updated_at_epoch_ms, device_id, sync_version)
VALUES (?, ?, ?, ?, ?, ?, ?, ?);

deleteTab:
DELETE FROM notebook_tabs WHERE id = ?;

selectColumnsByClass:
SELECT id, class_id, title, type, category_kind, instrument_kind, input_kind, evaluation_id, formula, weight, date_epoch_ms, unit_name, competency_criteria_ids_csv, scale_kind, tab_ids_csv, shared_across_tabs, color_hex, icon_name, sort_order, width_dp, category_id, visibility, is_locked, updated_at_epoch_ms, device_id, sync_version
FROM notebook_columns
WHERE class_id = ?
ORDER BY sort_order, id;

selectColumnById:
SELECT id, class_id, title, type, category_kind, instrument_kind, input_kind, evaluation_id, formula, weight, date_epoch_ms, unit_name, competency_criteria_ids_csv, scale_kind, tab_ids_csv, shared_across_tabs, color_hex, icon_name, sort_order, width_dp, category_id, visibility, is_locked, updated_at_epoch_ms, device_id, sync_version
FROM notebook_columns
WHERE id = ?;

selectColumnsByEvaluation:
SELECT id, class_id, title, type, category_kind, instrument_kind, input_kind, evaluation_id, formula, weight, date_epoch_ms, unit_name, competency_criteria_ids_csv, scale_kind, tab_ids_csv, shared_across_tabs, color_hex, icon_name, sort_order, width_dp, category_id, visibility, is_locked, updated_at_epoch_ms, device_id, sync_version
